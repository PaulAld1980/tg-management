# 1. За основу берем образ с предустановленным Node.js
FROM node:20-alpine

# 2. Наша рабочая папка
WORKDIR /app

# 3. Сначала копируем только списки зависимостей (оба файла package)
COPY package*.json ./

# 4. Скачиваем библиотеки внутри контейнера
RUN npm install

# 5. Копируем все ваши исходники (файлы Vue)
COPY . .

# 6. Запускаем сервер разработчика Vite.
# Флаг --host критически важен, чтобы Docker пробросил интерфейс наружу!
CMD ["npm", "run", "dev", "--", "--host"]
